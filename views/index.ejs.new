<!DOCTYPE html>
<html lang="es" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %></title>
    <!-- CSS & Libraries -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://unpkg.com/framer-motion@10.16.4/dist/framer-motion.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .status-pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    </style>
</head>
<body class="bg-[#0a0a0a] text-zinc-100 min-h-screen overflow-hidden">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useCallback } = React;
        const { motion, AnimatePresence } = FramerMotion;

        // Custom Component: Connection Indicator
        const ConnectivityIndicator = ({ status }) => (
            <div className="flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-900/50 border border-zinc-800">
                <div className={`w-2 h-2 rounded-full ${status ? 'bg-emerald-500 status-pulse shadow-[0_0_8px_rgba(16,185,129,0.6)]' : 'bg-zinc-600'}`} />
                <span className="text-xs font-medium text-zinc-400 capitalize">
                    {status ? 'Servidor Activo' : 'Cargando...'}
                </span>
            </div>
        );

        // Main Dashboard Application
        const Dashboard = () => {
            const [state, setState] = useState({
                clientReady: false,
                otraSession: false,
                src: null,
                loading: true,
                error: null
            });
            const [logs, setLogs] = useState([
                { id: 1, time: new Date().toLocaleTimeString(), msg: "Iniciando panel de control...", type: 'info' }
            ]);

            const addLog = (msg, type = 'info') => {
                setLogs(prev => [{ id: Date.now(), time: new Date().toLocaleTimeString(), msg, type }, ...prev].slice(0, 50));
            };

            const fetchData = useCallback(async () => {
                try {
                    const res = await fetch('/codigo');
                    const data = await res.json();
                    setState(prev => ({ ...prev, ...data, loading: false }));
                    
                    if (data.clientReady && !state.clientReady) {
                        addLog("WhatsApp conectado con éxito ✅", 'success');
                    }
                } catch (err) {
                    addLog("Error al sincronizar con el backend", 'error');
                }
            }, [state.clientReady]);

            useEffect(() => {
                const interval = setInterval(fetchData, 8000);
                fetchData();
                return () => clearInterval(interval);
            }, [fetchData]);

            const handleLogout = () => {
                addLog("Cerrando sesión...", 'warning');
                window.location.href = "/desconectar";
            };

            const handleRefresh = () => {
                addLog("Refrescando estado...", 'info');
                fetchData();
            };

            return (
                <div className="flex h-screen overflow-hidden">
                    {/* Sidebar */}
                    <div className="w-72 bg-[#0d0d0d] border-r border-zinc-800 flex flex-col p-6 hidden lg:flex">
                        <div className="flex items-center gap-3 mb-10 px-2">
                            <div className="p-2 bg-emerald-500/10 rounded-xl border border-emerald-500/20">
                                <lucide.Bot className="w-6 h-6 text-emerald-500" />
                            </div>
                            <h1 className="text-lg font-bold tracking-tight">ChatBot <span className="text-emerald-500">Pro</span></h1>
                        </div>

                        <nav className="flex-1 space-y-1">
                            {['Panorama', 'Historial', 'Configuración', 'API Info'].map((item, i) => (
                                <button key={item} className={`flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm font-medium transition-all ${i === 0 ? 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/10 shadow-[0_0_15px_rgba(16,185,129,0.05)]' : 'text-zinc-500 hover:text-zinc-300 hover:bg-zinc-900/50'}`}>
                                    {i === 0 && <lucide.LayoutDashboard className="w-4 h-4" />}
                                    {i === 1 && <lucide.History className="w-4 h-4" />}
                                    {i === 2 && <lucide.Settings className="w-4 h-4" />}
                                    {i === 3 && <lucide.Cpu className="w-4 h-4" />}
                                    {item}
                                </button>
                            ))}
                        </nav>

                        <div className="mt-auto p-4 glass rounded-2xl">
                            <h4 className="text-xs font-semibold text-zinc-500 uppercase mb-3">Soporte</h4>
                            <p className="text-xs text-zinc-400 leading-relaxed mb-4">Optimizado para alta disponibilidad y respuestas automáticas inteligentes.</p>
                            <button className="flex items-center gap-2 text-xs text-emerald-500 hover:text-emerald-400 font-medium transition-all">
                                <span>Ver documentación</span>
                                <lucide.ExternalLink className="w-3 h-3" />
                            </button>
                        </div>
                    </div>

                    {/* Main Content */}
                    <main className="flex-1 flex flex-col bg-[#0a0a0a] relative">
                        {/* Header */}
                        <header className="h-20 border-b border-zinc-800 flex items-center justify-between px-8 bg-[#0a0a0a]/80 backdrop-blur-sm z-10 sticky top-0">
                            <div className="flex items-center gap-4">
                                <div className="lg:hidden p-2 hover:bg-zinc-800 rounded-lg transition-all cursor-pointer">
                                    <lucide.Menu className="w-5 h-5 text-zinc-400" />
                                </div>
                                <div>
                                    <h2 className="text-sm font-semibold text-zinc-100">Panel Administrativo</h2>
                                    <p className="text-xs text-zinc-500 font-medium flex items-center gap-1.5 mt-0.5">
                                        Monitorizando sesión principal
                                    </p>
                                </div>
                            </div>

                            <div className="flex items-center gap-4">
                                <ConnectivityIndicator status={!state.loading} />
                                <div className="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 border border-white/10 shadow-lg shadow-emerald-500/10" />
                            </div>
                        </header>

                        {/* Scrollable Content Container */}
                        <div className="flex-1 overflow-y-auto p-8 space-y-8">
                            <div className="grid grid-cols-1 xl:grid-cols-2 gap-8">
                                {/* Connectivity Status Card */}
                                <motion.div 
                                    initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }}
                                    className="glass rounded-3xl p-8 flex flex-col items-center justify-center text-center relative overflow-hidden group min-h-[400px]"
                                >
                                    <div className="absolute top-0 right-0 p-6 opacity-20 group-hover:opacity-100 transition-opacity">
                                        <lucide.QrCode className="w-24 h-24 text-zinc-600" />
                                    </div>
                                    
                                    <AnimatePresence mode="wait">
                                        {!state.clientReady ? (
                                            <motion.div 
                                                key="qr-section"
                                                initial={{ scale: 0.9, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0.9, opacity: 0 }}
                                                className="flex flex-col items-center"
                                            >
                                                <div className="mb-6 relative">
                                                    <div className="absolute inset-0 bg-emerald-500/10 blur-3xl rounded-full" />
                                                    <div className="w-56 h-56 bg-white p-4 rounded-2xl shadow-2xl relative border border-white/10 ring-1 ring-black/5 overflow-hidden">
                                                        {state.src ? (
                                                            <img src={state.src} alt="WhatsApp QR" className="w-full h-full object-contain" />
                                                        ) : (
                                                            <div className="flex flex-col items-center justify-center h-full gap-3 text-zinc-300">
                                                                <div className="w-10 h-10 border-4 border-emerald-500/30 border-t-emerald-500 rounded-full animate-spin" />
                                                                <span className="text-[10px] font-medium tracking-wider">GENERANDO QR</span>
                                                            </div>
                                                        )}
                                                    </div>
                                                </div>
                                                <h3 className="text-xl font-bold mb-2">Vincular Dispositivo</h3>
                                                <p className="text-sm text-zinc-500 max-w-xs leading-relaxed">Escanea el código QR desde WhatsApp para habilitar las respuestas automáticas.</p>
                                            </motion.div>
                                        ) : (
                                            <motion.div 
                                                key="ready-section"
                                                initial={{ scale: 0.9, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0.9, opacity: 0 }}
                                                className="flex flex-col items-center"
                                            >
                                                <div className="w-32 h-32 bg-emerald-500/10 rounded-full flex items-center justify-center mb-8 relative">
                                                    <div className="absolute inset-0 bg-emerald-500/20 blur-2xl rounded-full animate-pulse" />
                                                    <lucide.CheckCircle2 className="w-16 h-16 text-emerald-500" />
                                                </div>
                                                <h3 className="text-2xl font-bold mb-3 tracking-tight">Chatbot en Línea</h3>
                                                <div className="flex items-center gap-2 px-4 py-2 bg-emerald-500/10 rounded-xl border border-emerald-500/10 mb-2">
                                                    <span className="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" />
                                                    <span className="text-xs font-bold text-emerald-500 uppercase tracking-widest leading-none pt-0.5">Operativo</span>
                                                </div>
                                                <p className="text-sm text-zinc-400 mt-4 leading-relaxed max-w-xs">El servidor está procesando mensajes entrantes en tiempo real.</p>
                                            </motion.div>
                                        )}
                                    </AnimatePresence>
                                </motion.div>

                                {/* Controls & Activity */}
                                <div className="space-y-8">
                                    {/* Action Panel Card */}
                                    <motion.div 
                                        initial={{ opacity: 0, x: 20 }} animate={{ opacity: 1, x: 0 }} transition={{ delay: 0.1 }}
                                        className="glass rounded-3xl p-8"
                                    >
                                        <div className="flex items-center justify-between mb-8">
                                            <h3 className="text-sm font-bold uppercase tracking-widest text-zinc-500">Centro de Control</h3>
                                            <lucide.Command className="w-5 h-5 text-zinc-700" />
                                        </div>

                                        <div className="grid grid-cols-2 gap-4">
                                            <button 
                                                onClick={handleRefresh}
                                                className="flex flex-col items-center gap-4 p-6 glass rounded-2xl hover:bg-white/5 transition-all text-zinc-400 hover:text-white border border-transparent hover:border-white/10 group"
                                            >
                                                <lucide.RefreshCw className="w-6 h-6 group-hover:rotate-180 transition-transform duration-500" />
                                                <span className="text-xs font-bold uppercase tracking-wider">Sincronizar</span>
                                            </button>
                                            <button 
                                                onClick={handleLogout}
                                                className="flex flex-col items-center gap-4 p-6 glass rounded-2xl hover:bg-emerald-500/10 transition-all text-zinc-400 hover:text-emerald-500 border border-transparent hover:border-emerald-500/20 group"
                                            >
                                                <lucide.Power className="w-6 h-6 group-hover:scale-110 transition-transform" />
                                                <span className="text-xs font-bold uppercase tracking-wider">Reiniciar</span>
                                            </button>
                                        </div>

                                        <div className="mt-8 p-6 bg-zinc-900/40 rounded-2xl border border-zinc-800/50">
                                            <div className="flex items-center gap-4">
                                                <div className="p-3 bg-zinc-800/50 rounded-xl">
                                                    <lucide.ShieldCheck className="w-5 h-5 text-zinc-500" />
                                                </div>
                                                <div className="flex-1">
                                                    <h5 className="text-xs font-bold text-zinc-300">Modo de Pruebas (Mock)</h5>
                                                    <p className="text-[10px] text-zinc-500 mt-0.5 leading-relaxed">Los mensajes no se enviarán a usuarios finales mientras este modo esté activo.</p>
                                                </div>
                                                <div className="w-10 h-5 bg-emerald-500/20 rounded-full relative p-1">
                                                    <div className="w-3 h-3 bg-emerald-500 rounded-full absolute right-1" />
                                                </div>
                                            </div>
                                        </div>
                                    </motion.div>

                                    {/* Activity Log Card */}
                                    <motion.div 
                                        initial={{ opacity: 0, x: 20 }} animate={{ opacity: 1, x: 0 }} transition={{ delay: 0.2 }}
                                        className="glass rounded-3xl p-8 flex-1 flex flex-col min-h-[250px]"
                                    >
                                        <div className="flex items-center justify-between mb-6">
                                            <h3 className="text-sm font-bold uppercase tracking-widest text-zinc-500">Monitor en Vivo</h3>
                                            <lucide.Activity className="w-5 h-5 text-zinc-700" />
                                        </div>
                                        
                                        <div className="flex-1 space-y-3 overflow-y-auto pr-2 max-h-[180px]">
                                            {logs.map(log => (
                                                <div key={log.id} className="flex gap-3 text-[10px] font-medium leading-relaxed group animate-in fade-in slide-in-from-left-2">
                                                    <span className="text-zinc-600 font-mono tracking-tighter w-14 shrink-0">{log.time}</span>
                                                    <span className={`flex-1 ${log.type === 'error' ? 'text-rose-500' : log.type === 'success' ? 'text-emerald-500' : 'text-zinc-400'}`}>
                                                        {log.msg}
                                                    </span>
                                                </div>
                                            ))}
                                            {logs.length === 0 && (
                                                <p className="text-xs text-zinc-600 italic text-center py-4">Sin actividad reciente</p>
                                            )}
                                        </div>
                                    </motion.div>
                                </div>
                            </div>
                        </div>

                        {/* Footer Status Bar */}
                        <footer className="h-10 border-t border-zinc-800 flex items-center px-8 bg-[#0d0d0d] gap-6 overflow-hidden shrink-0">
                            <div className="flex items-center gap-2">
                                <span className="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Version:</span>
                                <span className="text-[10px] font-bold text-zinc-400">v2.4.1</span>
                            </div>
                            <div className="flex items-center gap-2">
                                <span className="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Servidor:</span>
                                <span className="text-[10px] font-bold text-zinc-400">NodeJS <%= process.version %></span>
                            </div>
                            <div className="ml-auto flex items-center gap-4">
                                <div className="flex items-center gap-1.5 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all cursor-pointer">
                                    <lucide.Settings2 className="w-3 h-3" />
                                    <span className="text-[10px] font-bold text-zinc-500 uppercase tracking-wider">Ajustes</span>
                                </div>
                            </div>
                        </footer>
                    </main>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<Dashboard />);
        
        // Ensure Lucide icons can be replaced if needed, though we use <lucide.Icon /> pattern here for simplicity with CDN
        lucide.createIcons();
    </script>
</body>
</html>
